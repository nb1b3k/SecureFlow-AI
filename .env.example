# SecureFlow AI — environment template
# Copy to `.env` (which is gitignored) and fill in real values.
# NEVER commit a real key to git.

# Google AI Studio Gemini API key.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default Gemini model (default: gemini-2.5-flash-lite)
# Use gemini-2.0-flash for free-tier-only usage.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Groq API key — used when `.secureflow.yml > llm.provider: groq`.
# Get one free at https://console.groq.com/keys. Free tier: ~30 RPM,
# ~6,000 RPD on llama-3.1-8b-instant; smaller on the 70B variants.
# GROQ_API_KEY=

# Optional: override the default Groq model (default: llama-3.1-8b-instant).
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API key — used when .secureflow.yml > llm.provider: openrouter
# OR when openrouter appears in llm.fallback_providers. Get one free at
# https://openrouter.ai/settings/keys. Free :free models are typically
# capped at ~20 RPM and ~50 RPD per key (1000 RPD if you've purchased $10+
# in credits).
# OPENROUTER_AI_API_KEY=

# Optional: override the default OpenRouter model.
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# DeepSeek API key — used when .secureflow.yml > llm.provider: deepseek
# OR when deepseek appears in llm.fallback_providers (typically as the
# LAST link, after every free-tier provider has been exhausted).
# DeepSeek is a *paid* prepaid-balance provider; top up at
# https://platform.deepseek.com/. Pricing on `deepseek-chat` (V3):
# ~$0.27 per 1M input tokens, ~$1.10 per 1M output tokens — roughly
# $0.0024 per typical SecureFlow call.
# DEEPSEEK_API_KEY=

# Optional: override the default DeepSeek model.
# `deepseek-chat` (V3) is the price/perf default. `deepseek-reasoner` (R1)
# is ~2× the cost; only worth it if a specific run needs reasoning depth.
# DEEPSEEK_MODEL=deepseek-chat

# Required only when running in GitHub Actions mode.
# GITHUB_TOKEN=
# GITHUB_REPOSITORY=
# GITHUB_REF=
# GITHUB_EVENT_PATH=
